---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import HeroHexGrid from "../components/HeroHexGrid.astro";
import UseCases from "../components/UseCases.astro";
import Capabilities from "../components/Capabilities.astro";
import Audience from "../components/Audience.astro";
import InternalCTA from "../components/InternalCTA.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout>
  <Nav />
  <main class="landing-main relative overflow-hidden" data-hex-root>
    <HeroHexGrid />
    <Hero />
    <UseCases />
    <Capabilities />
    <Audience />
    <InternalCTA />
  </main>
  <Footer />
</BaseLayout>
