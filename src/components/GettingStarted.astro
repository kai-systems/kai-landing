---
import SectionHeading from "./ui/SectionHeading.astro";
import Button from "./ui/Button.astro";
---

<section id="get-started" class="py-20 md:py-32">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      label="Get Started"
      title="Get Started"
      subtitle="Download Kai for macOS and start transforming how you work."
    />

    <div class="space-y-6" data-reveal-stagger>
      <!-- Step 1 -->
      <div class="flex items-start gap-4 p-6 rounded-2xl glass-card glow-border" style="backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
        <span class="flex items-center justify-center w-8 h-8 rounded-full bg-gold-primary/15 text-gold-primary text-sm font-mono font-bold shrink-0 mt-0.5">1</span>
        <div>
          <h3 class="text-base font-heading font-semibold text-surface-200 mb-1">Download</h3>
          <p class="text-sm text-surface-400 mb-4">Get the latest Kai installer for macOS.</p>
          <Button href="https://github.com/kai-systems/kai/releases/latest/download/Kai.dmg" variant="primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" x2="12" y1="15" y2="3"/>
            </svg>
            Download Kai.dmg
          </Button>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="flex items-start gap-4 p-6 rounded-2xl glass-card glow-border" style="backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
        <span class="flex items-center justify-center w-8 h-8 rounded-full bg-gold-primary/15 text-gold-primary text-sm font-mono font-bold shrink-0 mt-0.5">2</span>
        <div>
          <h3 class="text-base font-heading font-semibold text-surface-200 mb-1">Install</h3>
          <p class="text-sm text-surface-400">Open the .dmg and drag Kai to your Applications folder. Launch it from Spotlight or your dock.</p>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="flex items-start gap-4 p-6 rounded-2xl glass-card glow-border" style="backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
        <span class="flex items-center justify-center w-8 h-8 rounded-full bg-gold-primary/15 text-gold-primary text-sm font-mono font-bold shrink-0 mt-0.5">3</span>
        <div>
          <h3 class="text-base font-heading font-semibold text-surface-200 mb-1">Start</h3>
          <p class="text-sm text-surface-400">Connect your accounts, configure your workspace, and start your first conversation. Kai adapts to how you work.</p>
        </div>
      </div>
    </div>

    <!-- Requirements note -->
    <div class="mt-8 text-center" data-reveal>
      <p class="inline-flex items-center gap-2 text-sm text-surface-400 px-4 py-2 rounded-full bg-surface-850 border border-white/5">
        <svg class="w-4 h-4 text-gold-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 16v-4"/>
          <path d="M12 8h.01"/>
        </svg>
        Requires macOS 13 (Ventura) or later.
      </p>
    </div>
  </div>
</section>
