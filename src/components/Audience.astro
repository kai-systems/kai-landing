---
const roles = [
  {
    title: "Engineers",
    description: "Trigger deployments, look up service owners, track incidents — without leaving the conversation.",
  },
  {
    title: "Product Managers",
    description: "Check project status, coordinate across teams, and surface blockers in seconds instead of meetings.",
  },
  {
    title: "Designers",
    description: "Submit requests, track handoff status, and stay connected to implementation without context-switching.",
  },
  {
    title: "DevOps & SRE",
    description: "Manage infrastructure, kick off pipelines, and respond to incidents through natural language.",
  },
  {
    title: "Data & Analytics",
    description: "Query dashboards, pull reports, and surface insights without hunting through multiple tools.",
  },
  {
    title: "Security & Compliance",
    description: "Run audits, check policy status, and track remediation across teams from a single interface.",
  },
  {
    title: "QA & Testing",
    description: "File bugs, check test results, and coordinate releases without switching between a dozen tabs.",
  },
  {
    title: "Team Leads & Executives",
    description: "See patterns across your organization — what's moving, what's stuck, and where to focus next.",
  },
];

const glassCardStyle = "backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);";
---

<section id="for-teams" class="py-20 md:py-32">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16" data-reveal>
      <span class="inline-block text-xs font-mono font-semibold tracking-widest uppercase text-gold-primary mb-4">
        Built for teams
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-surface-100 mb-4">
        One interface for every role
      </h2>
      <p class="text-lg text-surface-400 leading-relaxed">
        Everyone gets results in the form they need. No tool-hopping required.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-4" data-reveal-stagger>
      {roles.map((role) => (
        <div class="rounded-xl p-5 glass-card glow-border hover:border-gold-primary/25 hover:bg-white/[0.06] transition-all duration-300" style={glassCardStyle}>
          <h3 class="text-base font-heading font-semibold text-surface-100 mb-1.5">{role.title}</h3>
          <p class="text-sm text-surface-400 leading-relaxed">{role.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
