---
import SectionHeading from "./ui/SectionHeading.astro";
import GlowCard from "./ui/GlowCard.astro";

const features = [
  {
    title: "Conversational Interface",
    description: "Natural language interaction for every role. Ask questions, submit requests, and get answers — Kai translates human intent into action.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  },
  {
    title: "Communications Inbox",
    description: "Kai reaches out to the right people on your behalf. Reduces time spent figuring out who to contact and keeps communication centralized.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
  {
    title: "Task Board",
    description: "Visual Kanban board tracking work and delegated tasks. See each task's stage, who's working on it, and where everything stands at a glance.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>`,
  },
  {
    title: "Request Lifecycle",
    description: "End-to-end tracking from request to completion. Every request is classified, routed, executed, and delivered with full visibility throughout.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/><polyline points="22 2 12 12 16 16"/></svg>`,
  },
  {
    title: "Adaptive Learning",
    description: "Kai learns from every interaction — remembering preferences, surfacing patterns, and continuously improving its responses for your workflow.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>`,
  },
  {
    title: "Smart Routing",
    description: "Automatically classifies requests and routes them to the right handler — tool integrations, agent workflows, or direct responses.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`,
  },
  {
    title: "Cross-Role Access",
    description: "One interface for engineers, product managers, designers, and leaders. Each gets results in forms they can actually use — no tool-hopping required.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    title: "Team Analytics",
    description: "Visibility into request patterns, team velocity, bottlenecks, and trends. Data-driven insights for engineering leaders and stakeholders.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>`,
  },
];
---

<section id="features" class="py-20 md:py-32">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      label="Features"
      title="Capabilities"
      subtitle="Beyond conversation — Kai is where you start work, communicate about work, and follow it through to completion."
    />

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5" data-reveal-stagger>
      {features.map((feature) => (
        <GlowCard class="group">
          <div class="text-gold-primary mb-4 group-hover:text-cream transition-colors duration-300" set:html={feature.icon} />
          <h3 class="text-base font-heading font-semibold text-surface-100 mb-2">{feature.title}</h3>
          <p class="text-sm text-surface-400 leading-relaxed">{feature.description}</p>
        </GlowCard>
      ))}
    </div>
  </div>
</section>
