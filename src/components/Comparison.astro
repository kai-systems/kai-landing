---
import SectionHeading from "./ui/SectionHeading.astro";

const rows = [
  {
    them: "Generic chatbot responses",
    us: "Context-aware assistant that remembers your workflow",
  },
  {
    them: "Siloed communication tools",
    us: "Unified communications inbox",
  },
  {
    them: "Manual task tracking across tools",
    us: "Automatic request-to-task lifecycle",
  },
  {
    them: "No memory between sessions",
    us: "Adaptive learning from every interaction",
  },
  {
    them: "Single-purpose integrations",
    us: "Smart routing across tools and workflows",
  },
  {
    them: "No visibility into progress",
    us: "Real-time task board with status tracking",
  },
];

const glassCardStyle = "backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);";
---

<section id="comparison" class="py-20 md:py-32">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      label="Compare"
      title="Compare"
      subtitle="Most AI assistants are standalone chatbots. Kai is a full workspace — conversation, communication, and task tracking in one interface."
    />

    <div class="rounded-2xl overflow-hidden glass-card glow-border" data-reveal style={glassCardStyle}>
      <!-- Header -->
      <div class="grid grid-cols-2 border-b border-white/5">
        <div class="px-6 py-4 text-sm font-mono font-semibold text-surface-500 uppercase tracking-wider">
          Traditional Tools
        </div>
        <div class="px-6 py-4 text-sm font-mono font-semibold text-gold-primary uppercase tracking-wider border-l border-white/5">
          Kai
        </div>
      </div>

      <!-- Rows -->
      {rows.map((row, i) => (
        <div class:list={[
          "grid grid-cols-2",
          i < rows.length - 1 && "border-b border-white/5",
        ]}>
          <div class="px-6 py-4 text-surface-500 text-sm md:text-base flex items-center">
            <svg class="w-4 h-4 mr-3 text-surface-600 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 6 6 18" /><path d="m6 6 12 12" />
            </svg>
            {row.them}
          </div>
          <div class="px-6 py-4 text-surface-200 text-sm md:text-base border-l border-white/5 flex items-center">
            <svg class="w-4 h-4 mr-3 text-gold-primary shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12" />
            </svg>
            {row.us}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
