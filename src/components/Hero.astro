---
import Badge from "./ui/Badge.astro";
import siteConfig from "../../site.config.json";

const glassCardStyle = "backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);";
---

<section class="hero-section relative pt-32 pb-20 md:pt-44 md:pb-32 overflow-hidden">
  <!-- Background effects -->
  <div class="hero-visuals absolute inset-0 overflow-hidden">
    <div class="absolute inset-0 bg-grid-pattern opacity-40"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-gold-primary/8 rounded-full blur-[120px]"></div>
    <div class="hero-content-scrim absolute inset-x-0 top-0 bottom-0"></div>
  </div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Badge -->
    <div class="mb-8 animate-fade-in">
      <Badge>Open Source AI Assistant</Badge>
    </div>

    <!-- Headline -->
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-heading font-bold leading-[1.1] mb-6 animate-fade-up">
      <span class="text-gradient-gold">Action Through Intention</span>
    </h1>

    <!-- Subtitle -->
    <p class="text-lg md:text-xl text-surface-400 max-w-2xl mx-auto mb-10 leading-relaxed animate-fade-up" style="animation-delay: 100ms">
      An AI assistant that turns natural language into action — managing tasks, routing requests, and keeping your team in sync, all from one conversation.
    </p>

    <!-- CTAs -->
    <div class="flex items-center justify-center mb-12 animate-fade-up" style="animation-delay: 200ms">
      <a
        href={siteConfig.downloadUrl}
        class="download-btn inline-flex items-center gap-2 px-6 py-3 rounded-xl font-heading font-semibold text-sm bg-gradient-to-r from-gold-primary to-deep-amber text-white shadow-lg shadow-gold-primary/20 hover:shadow-xl hover:shadow-gold-primary/30 hover:-translate-y-0.5 transition-all duration-300 ease-out"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" x2="12" y1="15" y2="3"/>
        </svg>
        Download for macOS
      </a>
    </div>

    <!-- Example prompts -->
    <div class="inline-flex flex-col items-start gap-1.5 px-5 py-4 rounded-xl glass-card animate-fade-up" style={`animation-delay: 300ms; ${glassCardStyle}`}>
      <div class="flex items-center gap-3">
        <span class="text-gold-primary font-mono text-sm">></span>
        <code class="font-mono text-sm text-surface-200">Deploy the latest build to staging</code>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-gold-primary font-mono text-sm">></span>
        <code class="font-mono text-sm text-surface-200">What's blocking the auth service migration?</code>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-gold-primary font-mono text-sm">></span>
        <code class="font-mono text-sm text-surface-200">Set up a review with the frontend team for Thursday</code>
      </div>
    </div>
  </div>
</section>
