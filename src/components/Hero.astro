---
import Badge from "./ui/Badge.astro";
import Button from "./ui/Button.astro";

const stats = [
  { value: "Open", label: "Source" },
  { value: "macOS", label: "Native App" },
  { value: "All", label: "Roles Supported" },
  { value: "Fast", label: "Response Time" },
];

const glassCardStyle = "backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);";
---

<section class="hero-section relative pt-32 pb-20 md:pt-44 md:pb-32 overflow-hidden">
  <!-- Background effects -->
  <div class="hero-visuals absolute inset-0 overflow-hidden">
    <div class="absolute inset-0 bg-grid-pattern opacity-40"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-gold-primary/8 rounded-full blur-[120px]"></div>
    <div class="hero-content-scrim absolute inset-x-0 top-0 bottom-0"></div>
  </div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Badge -->
    <div class="mb-8 animate-fade-in">
      <Badge>Open Source AI Assistant</Badge>
    </div>

    <!-- Headline -->
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-heading font-bold leading-[1.1] mb-6 animate-fade-up">
      <span class="text-gradient-gold">Where Intent</span>
      <br />
      <span class="text-surface-100">Becomes Action</span>
    </h1>

    <!-- Subtitle -->
    <p class="text-lg md:text-xl text-surface-400 max-w-2xl mx-auto mb-10 leading-relaxed animate-fade-up" style="animation-delay: 100ms">
      Kai is an open-source conversational AI assistant with built-in task tracking, a communications inbox, and smart request routing — all through natural language.
    </p>

    <!-- Example prompts -->
    <div class="inline-flex flex-col items-start gap-1 px-5 py-3 rounded-xl glass-card mb-8 animate-fade-up" style={`animation-delay: 200ms; ${glassCardStyle}`}>
      <div class="flex items-center gap-3">
        <span class="text-gold-primary font-mono text-sm">></span>
        <code class="font-mono text-sm text-surface-200">Deploy the latest build to staging</code>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-gold-primary font-mono text-sm">></span>
        <code class="font-mono text-sm text-surface-200">Show me the status of PROJ-1234</code>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-gold-primary font-mono text-sm">></span>
        <code class="font-mono text-sm text-surface-200">Who should I talk to about the auth service?</code>
      </div>
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 animate-fade-up" style="animation-delay: 300ms">
      <Button href="https://github.com/kai-systems/kai/releases/latest/download/Kai.dmg" variant="primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" x2="12" y1="15" y2="3"/>
        </svg>
        Download for macOS
      </Button>
      <Button href="https://github.com/kai-systems/kai" variant="secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        View on GitHub
      </Button>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 max-w-2xl mx-auto animate-fade-up" style="animation-delay: 400ms">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-2xl md:text-3xl font-heading font-bold text-cream">{stat.value}</div>
          <div class="text-xs md:text-sm text-surface-500 mt-1 font-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
