---
interface Props {
  href: string;
  variant?: "primary" | "secondary";
  class?: string;
  external?: boolean;
}

const { href, variant = "primary", class: className = "", external = true } = Astro.props;
const target = external ? "_blank" : undefined;
const rel = external ? "noopener noreferrer" : undefined;
---

{variant === "primary" ? (
  <a
    href={href}
    target={target}
    rel={rel}
    class:list={[
      "inline-flex items-center gap-2 px-6 py-3 rounded-xl font-heading font-semibold text-sm",
      "bg-gradient-to-r from-gold-primary to-deep-amber",
      "text-white shadow-lg shadow-gold-primary/20",
      "hover:shadow-xl hover:shadow-gold-primary/30 hover:-translate-y-0.5",
      "transition-all duration-300 ease-out",
      className,
    ]}
  >
    <slot />
  </a>
) : (
  <a
    href={href}
    target={target}
    rel={rel}
    class:list={[
      "inline-flex items-center gap-2 px-6 py-3 rounded-xl font-heading font-semibold text-sm",
      "bg-white/[0.03] backdrop-blur-md",
      "border border-gold-primary/30 text-cream",
      "hover:bg-gold-primary/10 hover:border-gold-primary/50 hover:-translate-y-0.5",
      "transition-all duration-300 ease-out",
      className,
    ]}
    style="backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);"
  >
    <slot />
  </a>
)}
