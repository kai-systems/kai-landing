---
import SectionHeading from "./ui/SectionHeading.astro";
import GlowCard from "./ui/GlowCard.astro";

const components = [
  {
    name: "Conversational Interface",
    role: "Natural Language Input",
    description: "Ask questions, submit requests, and manage your workflow through natural conversation. Kai understands context, intent, and follows up intelligently.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  },
  {
    name: "Smart Routing",
    role: "Intelligent Dispatch",
    description: "Kai classifies your request and routes it to the right handler — whether that's a tool integration, an agent workflow, or a direct response.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h5"/><path d="M17 12h5"/><path d="m7 7 5 5-5 5"/><path d="m12 7 5 5-5 5"/></svg>`,
  },
  {
    name: "Task Engine",
    role: "Lifecycle Management",
    description: "Every request becomes a tracked task with status, updates, and completion signals. A visual Kanban board shows where everything stands at a glance.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="m9 12 2 2 4-4"/></svg>`,
  },
  {
    name: "Learning Loop",
    role: "Continuous Improvement",
    description: "Kai learns from every interaction — surfacing patterns, remembering preferences, and adapting to how you and your team work over time.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/><polyline points="22 2 12 12 16 16"/></svg>`,
  },
];

const requestFlow = [
  "Request Received", "Intent Classification", "Context Enrichment",
  "Route Selection", "Task Creation", "Execution",
  "Progress Tracking", "Result Delivery", "Feedback Capture",
];
---

<section id="how-it-works" class="py-20 md:py-32">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      label="How It Works"
      title="How It Works"
      subtitle="From natural language to tracked results — Kai translates what you mean into what gets done."
    />

    <!-- Core Components -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16" data-reveal-stagger>
      {components.map((comp) => (
        <GlowCard>
          <div class="text-gold-primary mb-4" set:html={comp.icon} />
          <h3 class="text-lg font-heading font-bold text-surface-100 mb-1">{comp.name}</h3>
          <span class="text-xs font-mono text-gold-primary/80 uppercase tracking-wider">{comp.role}</span>
          <p class="text-sm text-surface-400 mt-3 leading-relaxed">{comp.description}</p>
        </GlowCard>
      ))}
    </div>

    <!-- Request Flow -->
    <div data-reveal>
      <h3 class="text-center text-lg font-heading font-semibold text-surface-200 mb-6">
        Request Lifecycle
      </h3>
      <div class="flex flex-wrap justify-center gap-2 max-w-3xl mx-auto">
        {requestFlow.map((phase, i) => (
          <div class="flex items-center gap-2">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm text-surface-200 font-medium glass-card glow-border hover:border-gold-primary/25 hover:bg-white/[0.06] transition-all duration-300" style="backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
              <span class="text-xs text-gold-primary/60 font-mono">{i + 1}</span>
              {phase}
            </span>
            {i < requestFlow.length - 1 && (
              <svg class="w-3 h-3 text-surface-600 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6" />
              </svg>
            )}
          </div>
        ))}
      </div>
      <p class="text-center text-sm text-surface-500 mt-4">
        Every request flows through classification, routing, and tracking — nothing falls through the cracks.
      </p>
    </div>
  </div>
</section>
